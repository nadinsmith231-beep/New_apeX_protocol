{
  "version": 2,
  "builds": [
    {
      "src": "Myhtmlfiles/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "Myhtmlfiles/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "Java/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "NFT_IMAGE/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/Myhtmlfiles/entry.html"
    },
    {
      "src": "/target",
      "dest": "/Myhtmlfiles/target.html"
    },
    {
      "src": "/safe",
      "dest": "/Myhtmlfiles/safe.html"
    },
    
    {
      "src": "/Java/(.*)",
      "dest": "/Java/$1"
    },
    {
      "src": "/NFT_IMAGE/(.*)",
      "dest": "/NFT_IMAGE/$1"
    }
  ]
}
