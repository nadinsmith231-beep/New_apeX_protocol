{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "Java/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "NFT_IMAGE/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/target.html"
    }
  ]
}
